# =============================================================================
# E2E Test Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values as needed.
# Default values target the isolated E2E Docker stack.
# =============================================================================

# --- Application URLs ---
E2E_BASE_URL=http://localhost:3001
E2E_API_URL=http://localhost:8001/api/v1
E2E_WS_URL=ws://localhost:8001/ws

# --- PostgreSQL (E2E-isolated, port 5433) ---
E2E_DB_HOST=localhost
E2E_DB_PORT=5433
E2E_DB_NAME=backend_core_e2e_db
E2E_DB_USER=django_user
E2E_DB_PASSWORD=django_password

# --- Redis (E2E-isolated, port 6380) ---
E2E_REDIS_URL=redis://localhost:6380/0

# --- Test Defaults ---
E2E_DEFAULT_PASSWORD=testpass123
E2E_TIMEOUT=30000
E2E_ACTION_TIMEOUT=15000

# --- Feature Gate Config ---
# Path to deployment_config.json (relative to backend/)
E2E_DEPLOYMENT_CONFIG_PATH=../backend/deployment_config.json
