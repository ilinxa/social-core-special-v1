# Dependencies
node_modules/

# Environment
.env

# Playwright artifacts (root-relative to avoid matching docs/reports/)
/playwright-report/
/reports/
/test-results/
/blob-report/

# Storage states (generated by global-setup, contain auth tokens)
fixtures/storage-states/*.json
!fixtures/storage-states/.gitkeep

# Visual regression baselines are tracked in git
# but screenshots from failed runs are not
tests/__screenshots__/**/diff/
tests/__screenshots__/**/actual/

# Video recordings
videos/

# Traces
traces/

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# TypeScript build artifacts (should never exist — noEmit: true)
*.js.map
*.d.ts
