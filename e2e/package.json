{
  "name": "e2e-tests",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright E2E tests for the User scope checklist (U-01 to U-99)",
  "scripts": {
    "test": "npx playwright test",
    "test:ui": "npx playwright test --ui",
    "test:headed": "npx playwright test --headed",
    "test:debug": "npx playwright test --debug",
    "report": "npx playwright show-report reports/e2e-html",
    "install:browsers": "npx playwright install --with-deps chromium"
  },
  "dependencies": {
    "@playwright/test": "^1.50.0",
    "pg": "^8.13.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "typescript": "^5.7.0"
  }
}
