# ============================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================
# This file serves as a template for production deployment.
# 
# Setup Instructions:
#   1. Copy this file: cp .env.example .env
#   2. Fill in ALL required values below
#   3. NEVER commit the actual .env file to version control
#   4. Use strong, randomly generated values for secrets
# ============================================

# ============================================
# DJANGO CORE CONFIGURATION
# ============================================

# Settings module (DO NOT CHANGE for production)
DJANGO_SETTINGS_MODULE=backend_core.settings.production

# CRITICAL: Generate a strong secret key
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=CHANGE-THIS-TO-A-RANDOM-SECRET-KEY-50-CHARS-MINIMUM

# Debug mode (MUST be False in production)
DEBUG=False

# Allowed hosts (comma-separated, NO SPACES)
# Example: ALLOWED_HOSTS=example.com,www.example.com,api.example.com
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# ============================================
# DATABASE CONFIGURATION (PostgreSQL)
# ============================================
# PostgreSQL credentials - use STRONG passwords in production

POSTGRES_DB=backend_core_db
POSTGRES_USER=django_user
POSTGRES_PASSWORD=CHANGE-THIS-TO-A-STRONG-PASSWORD
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ============================================
# REDIS CONFIGURATION
# ============================================
# Redis connection URL for caching and Channels
# Format: redis://[user:password@]host:port[/db]
# Docker service name: redis://redis:6379
# External Redis: redis://username:password@redis-host:6379/0

REDIS_URL=redis://redis:6379

# ============================================
# CORS CONFIGURATION
# ============================================
# Allowed origins for CORS (comma-separated, NO SPACES)
# Include your frontend domain(s) here
# Example: CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com

CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================
# STATIC & MEDIA FILES CONFIGURATION
# ============================================

# Cloud storage toggle
# Set to 'true' to use S3/Cloudflare R2, 'false' for local/nginx serving
USE_S3=false

# --------------------------------------------
# AWS S3 / Cloudflare R2 Configuration
# (Only needed if USE_S3=true)
# --------------------------------------------

# AWS Access Credentials
# For S3: Get from AWS IAM console
# For Cloudflare R2: Get from R2 dashboard > Manage R2 API Tokens
# AWS_ACCESS_KEY_ID=your-access-key-here
# AWS_SECRET_ACCESS_KEY=your-secret-access-key-here

# Bucket name
# AWS_STORAGE_BUCKET_NAME=your-bucket-name

# Region
# For AWS S3: us-east-1, eu-west-1, etc.
# For Cloudflare R2: use 'auto'
# AWS_S3_REGION_NAME=auto

# Endpoint URL
# For AWS S3: Leave commented out (uses default AWS endpoints)
# For Cloudflare R2: https://<account-id>.r2.cloudflarestorage.com
# AWS_S3_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com

# Custom domain (CDN)
# If you have a CDN/custom domain pointing to your S3/R2 bucket
# Example: AWS CloudFront or Cloudflare CDN
# AWS_S3_CUSTOM_DOMAIN=cdn.yourdomain.com

# ============================================
# EMAIL CONFIGURATION
# ============================================

# Email backend
# Options: 
#   - django.core.mail.backends.smtp.EmailBackend (production)
#   - django.core.mail.backends.console.EmailBackend (testing)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# SMTP Settings
# Examples:
#   Gmail: smtp.gmail.com:587
#   SendGrid: smtp.sendgrid.net:587
#   Mailgun: smtp.mailgun.org:587
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True

# SMTP Credentials
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-app-specific-password

# Default sender email
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ============================================
# SECURITY SETTINGS
# ============================================

# Force HTTPS redirect (set to False only if using external SSL termination)
SECURE_SSL_REDIRECT=True

# ============================================
# CELERY CONFIGURATION
# ============================================
# Redis URL for Celery task broker and result backend
# Default: redis://redis:6379/0 (Docker service name)

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ============================================
# JWT / AUTH CONFIGURATION
# ============================================
# Access token lifetime in seconds (default: 900 = 15 minutes)
JWT_ACCESS_TOKEN_LIFETIME=900

# Refresh token lifetime in seconds (default: 604800 = 7 days)
JWT_REFRESH_TOKEN_LIFETIME=604800

# Maximum active sessions per user (default: 5)
AUTH_MAX_SESSIONS_PER_USER=5

# ============================================
# OAUTH CONFIGURATION
# ============================================
# Google OAuth (leave empty to disable Google login)
# GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
# GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# Apple OAuth (leave empty to disable Apple login)
# APPLE_OAUTH_CLIENT_ID=your-apple-services-id
# APPLE_OAUTH_TEAM_ID=your-apple-team-id
# APPLE_OAUTH_KEY_ID=your-apple-key-id
# APPLE_OAUTH_PRIVATE_KEY=your-apple-private-key

# ============================================
# URL CONFIGURATION
# ============================================
# Frontend URL (for OAuth redirects and email links)
FRONTEND_URL=https://yourdomain.com

# Backend URL (for OAuth callbacks)
BACKEND_URL=https://api.yourdomain.com

# ============================================
# ADMIN NOTIFICATIONS
# ============================================
# Admins who receive error emails (format: Name:email,Name2:email2)
# DJANGO_ADMINS=Admin:admin@yourdomain.com

# ============================================
# OPTIONAL: MONITORING & ERROR TRACKING
# ============================================

# Sentry DSN (if using Sentry for error tracking)
# Uncomment and set if you want error monitoring
# SENTRY_DSN=https://your-sentry-dsn-here

# ============================================
# DEPLOYMENT CHECKLIST
# ============================================
# Before deploying, ensure:
# ✓ DJANGO_SECRET_KEY is changed to a random value
# ✓ DEBUG is set to False
# ✓ ALLOWED_HOSTS contains your actual domain(s)
# ✓ Strong POSTGRES_PASSWORD is set
# ✓ SSL certificates are configured (if SECURE_SSL_REDIRECT=True)
# ✓ CORS_ALLOWED_ORIGINS includes your frontend domain
# ✓ Email settings are configured and tested
# ✓ Backup strategy is in place for database and media files