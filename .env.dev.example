# ============================================
# LOCAL DOCKER DEVELOPMENT ENVIRONMENT
# ============================================
# This file is for HYBRID development mode:
# - Infrastructure (PostgreSQL, Redis) runs in Docker
# - Django runs locally on your machine
#
# Usage:
#   1. Copy this file: cp .env.dev.example .env.dev
#   2. Start infrastructure: docker-compose -f docker-compose.dev.yml up -d
#   3. Run Django: python manage.py runserver --settings=backend_core.settings.local_docker
# ============================================

# ============================================
# DJANGO CONFIGURATION
# ============================================
# Settings module to use (DO NOT CHANGE for dev)
DJANGO_SETTINGS_MODULE=backend_core.settings.local_docker

# Debug mode (always True for development)
DEBUG=True

# Allowed hosts (comma-separated, permissive for local dev)
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ============================================
# DATABASE CONFIGURATION
# ============================================
# PostgreSQL running in Docker, exposed on localhost:5432
# These values MUST match docker-compose.dev.yml

POSTGRES_DB=backend_core_db
POSTGRES_USER=django_user
POSTGRES_PASSWORD=postgres_dev_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ============================================
# REDIS CONFIGURATION
# ============================================
# Redis running in Docker, exposed on localhost:6379
# Used for: Channels layer, caching, sessions

REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================
# CORS CONFIGURATION (OPTIONAL)
# ============================================
# Uncomment and set if you're developing a frontend separately
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================
# NOTES:
# ============================================
# - This file is for LOCAL DEVELOPMENT ONLY
# - Never commit actual .env.dev file to version control
# - PostgreSQL and Redis ports must be free on your machine
# - To reset database: docker-compose -f docker-compose.dev.yml down -v