# E2E Docker build — repo-root context
# Exclude heavy directories not needed by backend or frontend builds

# Git
.git/

# Node modules (frontend installs fresh via npm ci)
frontend/node_modules/
e2e/node_modules/

# Python virtualenvs
backend/venv/
backend/.venv/
backend/__pycache__/

# Build artifacts
frontend/.next/
frontend/out/
backend/staticfiles/
backend/media/

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Test artifacts
backend/.pytest_cache/
backend/htmlcov/
e2e/test-results/
e2e/playwright-report/

# Documentation (not needed in Docker)
docs/
progress/
mobile/
